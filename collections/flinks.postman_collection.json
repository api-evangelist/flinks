        {
          "name": "Generate a short-lived authorize token.",
          "request": {
            "name": "Generate a short-lived authorize token.",
            "description": {
              "content": "Exchanges your API secret for a 30-minute authorize token supplied in the flinks-auth-key header.",
              "type": "text/plain"
            },
            "url": {
              "raw": "{{baseUrl}}/GenerateAuthorizeToken",
